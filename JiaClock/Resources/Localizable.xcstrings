    "legal.privacy.section.changes.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We may update this Privacy Policy from time to time. Continued use of the app after changes take effect constitutes acceptance of the updated policy."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们可能不时更新本隐私政策。更新生效后你继续使用 App，即视为接受更新后的政策。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我們可能不時更新本隱私政策。更新生效後你繼續使用 App，即視為接受更新後的政策。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本ポリシーは随時更新される場合があります。更新後も利用を続ける場合、更新内容に同意したものとみなします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "본 방침은 수시로 업데이트될 수 있습니다. 변경 후에도 앱을 계속 사용하면 업데이트된 방침에 동의한 것으로 봅니다."
          }
        }
      }
    },
