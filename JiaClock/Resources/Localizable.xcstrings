      }
    },
    "legal.privacy.section.widget.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Home screen widgets display time and your chosen clock settings only. Widgets do not access or use the camera."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "主屏幕小组件仅显示时间与你在 App 中选择的时钟设置，不会访问或使用摄像头。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "主畫面小組件僅顯示時間與你在 App 中選擇的時鐘設定，不會存取或使用相機。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホーム画面ウィジェットは時刻と設定した時計表示のみを行い、カメラにはアクセスしません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "홈 화면 위젯은 시간과 선택한 시계 설정만 표시하며 카메라에 접근하지 않습니다."
          }
        }
      }
    },
    "legal.privacy.section.purchases.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Purchases and Subscriptions"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "购买与订阅"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "購買與訂閱"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "購入とサブスクリプション"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구매 및 구독"
          }
        }
      }
    },
    "legal.privacy.section.purchases.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In-app purchases and subscriptions are processed by Apple through StoreKit. We do not receive or store your payment card details. Apple's terms and privacy practices apply to payment processing."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "App 内购买与订阅由 Apple 通过 StoreKit 处理。我们不会接收或保存你的支付卡信息。支付处理适用 Apple 的相关条款与隐私政策。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "App 內購買與訂閱由 Apple 透過 StoreKit 處理。我們不會接收或保存你的支付卡資訊。支付處理適用 Apple 的相關條款與隱私政策。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリ内課金とサブスクリプションは Apple の StoreKit により処理されます。当方はカード情報を受け取らず保存もしません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱 내 구매와 구독은 Apple StoreKit으로 처리됩니다. 당사는 결제 카드 정보를 받거나 저장하지 않습니다."
          }
        }
      }
    },
    "legal.privacy.section.storage.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Information Stored on Your Device"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存在你设备上的信息"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "保存在你裝置上的資訊"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "端末に保存される情報"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기에 저장되는 정보"
          }
        }
      }
    },
    "legal.privacy.section.storage.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Jia Clock may save your preferences locally on your device, such as theme, custom tagline, and time display options.\n\nIf App Group storage is used, it is only to share these clock settings between the main app and the widget extension. Camera data is never shared through App Group."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "小嘉时钟可能在本机保存你的偏好设置，例如主题、自定义标语、时间显示格式等。\n\n如使用 App Group，其用途仅限于在主 App 与 Widget 扩展之间共享上述时钟设置，不会通过 App Group 共享任何摄像头数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "小嘉時鐘可能在本機保存你的偏好設定，例如主題、自訂標語、時間顯示格式等。\n\n如使用 App Group，其用途僅限於在主 App 與 Widget 擴展之間共享上述時鐘設定，不會透過 App Group 共享任何相機資料。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "テーマ、标语、時刻表示形式などの設定を端末内に保存することがあります。\n\nApp Group を使用する場合も、メインアプリとウィジェット間でこれらの設定を共有する目的に限り、カメラデータは共有しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "테마, 사용자 슬로건, 시간 표시 형식 등 설정을 기기에 저장할 수 있습니다.\n\nApp Group은 앱과 위젯 간 시계 설정 공유에만 사용되며 카메라 데이터는 공유하지 않습니다."
          }
        }
      }
    },
    "legal.privacy.section.changes.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Changes to This Policy"
          }
        },
        "zh-Hans": {
          "stringUnit": {
