    "home.widget_guide_title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add Widget to Home Screen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホーム画面にウィジェットを追加"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "홈 화면에 위젯 추가"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加桌面组件"
