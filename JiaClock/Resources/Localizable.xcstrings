    "transparent.camera_unavailable_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Simulator has no rear camera. Please test transparent clock on a real iPhone or iPad."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "シミュレーターには背面カメラがありません。実機の iPhone または iPad でお試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시뮬레이터에는 후면 카메라가 없습니다. 실제 iPhone 또는 iPad에서 테스트해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模拟器没有后置摄像头，请在真机 iPhone 或 iPad 上体验透明时钟。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "模擬器沒有後置相機，請在真機 iPhone 或 iPad 上體驗透明時鐘。"
          }
        }
      }
