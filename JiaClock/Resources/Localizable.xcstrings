        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "加入桌面組件"
          }
        }
      }
    },
    "home.widget_guide_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Long-press the home screen, tap +, search for Jia Clock, and choose small, medium, or large. Widget time updates by the minute, not every second."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホーム画面を長押しし、＋から「小嘉クロック」を選んで小・中・大サイズを追加できます。時刻は分単位で更新されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "홈 화면을 길게 누르고 +에서 '샤오지아 시계'를 검색해 소·중·대 크기를 추가하세요. 시간은 분 단위로 갱신됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "长按主屏幕 → 点击左上角 + → 搜索「小嘉时钟」→ 选择小、中、大组件。时间按分钟刷新，非秒级实时。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "長按主畫面 → 點擊左上角 + → 搜尋「小嘉時鐘」→ 選擇小、中、大組件。時間按分鐘刷新，非秒級即時。"
          }
        }
      }
    },
