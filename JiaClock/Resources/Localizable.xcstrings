    "transparent.permission_denied_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please enable camera access in Settings to use transparent clock."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "透明時計を使うには、設定でカメラへのアクセスを許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "투명 시계를 사용하려면 설정에서 카메라 접근을 허용해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在系统设置中开启摄像头权限，以使用透明时钟。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請在系統設定中開啟相機權限，以使用透明時鐘。"
          }
        }
      }
    },
    "transparent.permission_restricted_title": {
      "localizations": {
