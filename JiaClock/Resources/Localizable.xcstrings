        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "透明時鐘" } }
      }
    },
    "transparent.headline" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "See time blend into your real world" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "時計を現実の風景に溶け込ませる" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "시간을 현실 풍경에 자연스럽게 녹여보세요" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "让时钟融入你的真实世界" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "讓時鐘融入你的真實世界" } }
      }
    },
    "transparent.value1_title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Aesthetic desktop companion" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "美しいデスクコンパニオン" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "아름다운 데스크탑 동반자" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "美学桌面伴侣" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "美學桌面伴侶" } }
      }
    },
    "transparent.value1_body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Layer elegant clock typography over your desk, window, or workspace for a living screensaver feel." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "机、窓、ワークスペースの上に上品な時計を重ね、生きているスクリーンセーバーのような体験を。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "책상, 창가, 작업 공간 위에 우아한 시계를 겹쳐 살아 있는 화면 보호기 같은 경험을 제공합니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "在桌面、窗边或工作区上叠加优雅时钟，呈现有生命力的屏保体验。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "在桌面、窗邊或工作區上疊加優雅時鐘，呈現有生命力的螢幕保護程式體驗。" } }
      }
    },
    "transparent.value2_title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Perfect for StandBy & focus" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "StandBy と集中に最適" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "StandBy 와 집중에 적합" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "适合 StandBy 与专注场景" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "適合 StandBy 與專注場景" } }
      }
    },
    "transparent.value2_body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Use as a bedside display or focus companion without blocking your environment." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "環境を遮らず、ベッドサイド表示や集中用コンパニオンとして使えます。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "주변 환경을 가리지 않고 침대 옆 디스플레이나 집중 동반자로 사용할 수 있습니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "可作为床头屏或专注伴侣，不遮挡你的真实环境。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "可作為床頭屏或專注伴侶，不遮擋你的真實環境。" } }
      }
    },
    "transparent.permission_title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Camera permission required" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "カメラ権限が必要です" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "카메라 권한이 필요합니다" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "需要摄像头权限" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "需要相機權限" } }
      }
    },
    "transparent.permission_body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Transparent clock uses the rear camera preview as a live background. Permission is only used for on-device preview." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "透明時計は背面カメラのプレビューをライブ背景として使用します。権限は端末内プレビューのみに使用されます。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "투명 시계는 후면 카메라 미리보기를 라이브 배경으로 사용합니다. 권한은 기기 내 미리보기에만 사용됩니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "透明时钟使用后置摄像头预览作为实时背景，权限仅用于设备内预览。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "透明時鐘使用後置相機預覽作為即時背景，權限僅用於裝置內預覽。" } }
      }
    },
    "transparent.privacy_title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your privacy is protected" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "プライバシーは保護されます" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "개인정보는 보호됩니다" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "你的隐私受到保护" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "你的隱私受到保護" } }
      }
    },
    "transparent.privacy_body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The camera is used only as a live background. We do not record, save, or upload any camera content." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "カメラはリアルタイム背景のみに使用します。録画、保存、アップロードは一切行いません。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "카메라는 실시간 배경으로만 사용됩니다. 녹화, 저장, 업로드는 하지 않습니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "摄像头仅用于实时背景，不会录制、保存或上传任何画面内容。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "相機僅用於即時背景，不會錄製、保存或上傳任何畫面內容。" } }
      }
    },
    "transparent.background_stop_title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Stops when you leave" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "離れると自動停止" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "나가면 자동 중지" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "切后台自动停止" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "切後台自動停止" } }
      }
    },
    "transparent.background_stop_body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The camera stops when you leave this screen, switch apps, or lock your device. It never runs in the background." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "画面を離れる、アプリを切り替える、端末をロックするとカメラは停止します。バックグラウンドでは動作しません。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "화면을 나가거나 앱을 전환하거나 기기를 잠그면 카메라가 중지됩니다. 백그라운드에서는 실행되지 않습니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "离开页面、切换 App 或锁屏时，相机会自动停止，绝不在后台继续采集。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "離開頁面、切換 App 或鎖屏時，相機會自動停止，絕不在背景繼續採集。" } }
      }
    },
