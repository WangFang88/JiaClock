    "transparent.permission_restricted_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is restricted on this device. Transparent clock cannot be enabled."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この端末ではカメラへのアクセスが制限されています。透明時計を有効にできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기에서는 카메라 접근이 제한되어 투명 시계를 사용할 수 없습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备的摄像头权限受到限制，无法开启透明时钟。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此裝置的相機權限受到限制，無法開啟透明時鐘。"
          }
        }
      }
