    "pro.paywall_subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make your desk clock truly yours — premium themes, transparent modes, widgets, and more."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デスク時計を本当に自分だけのものに——プレミアムテーマ、透明モード、ウィジェットなど。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "데스크 시계를 진짜 나만의 것으로——프리미엄 테마, 투명 모드, 위젯 등."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让桌面时钟真正属于你——高级主题、透明模式、组件样式与更多专属能力。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讓桌面時鐘真正屬於你——進階主題、透明模式、組件樣式與更多專屬能力。"
          }
        }
      }
    },
    "pro.paywall_value_headline": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Designed for calm, beautiful time"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "静かで美しい時間のために"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "조용하고 아름다운 시간을 위해"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为安静、好看的桌面时间而设计"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為安靜、好看的桌面時間而設計"
          }
        }
      }
    },
    "pro.paywall_value_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro unlocks the full aesthetic toolkit — from premium themes to advanced transparent and widget styles — so your clock matches your mood, desk, and workflow."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro で美学ツールキットを解放。プレミアムテーマ、透明時計、ウィジェット、カスタムなど、あなたのデスクに合わせます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro로 프리미엄 테마, 투명 시계, 위젯, 사용자 지정 등 전체 미학 도구를 잠금 해제합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro 解锁完整美学工具箱：高级主题、透明时钟高级模式、组件样式、自定义字体与颜色等，让时钟融入你的桌面与创作场景。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro 解鎖完整美學工具箱：進階主題、透明時鐘進階模式、組件樣式、自訂字體與顏色等，讓時鐘融入你的桌面與創作場景。"
          }
        }
      }
    },
