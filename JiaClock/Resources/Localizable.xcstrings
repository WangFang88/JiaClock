    "legal.terms.intro": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These Terms of Service (「Terms」) govern your use of Jia Clock (「小嘉时钟」, the 「App」). By using the App, you agree to these Terms."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本用户协议（「协议」）适用于你对小嘉时钟（「App」）的使用。使用 App 即表示你同意本协议。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本使用者協議（「協議」）適用於你對小嘉時鐘（「App」）的使用。使用 App 即表示你同意本協議。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本利用規約（「規約」）は、小嘉クロック（「本アプリ」）の利用条件を定めます。利用により規約に同意したものとみなします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "본 이용약관(「약관」)은 Jia Clock(小嘉时钟) 앱 이용에 적용됩니다. 앱을 사용하면 본 약관에 동의한 것으로 봅니다."
          }
        }
      }
    },
    "legal.terms.section.service.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Service Description"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务说明"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "服務說明"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サービス内容"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "서비스 설명"
          }
        }
      }
    },
    "legal.terms.section.service.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Jia Clock provides aesthetic clock displays, including full-screen clock, flip clock, transparent clock (camera preview background), and home screen widgets. Features may vary by device, system version, and subscription status."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "小嘉时钟提供美学时钟显示功能，包括全屏时钟、翻页时钟、透明时钟（摄像头预览背景）及主屏幕小组件。具体功能可能因设备、系统版本及订阅状态而有所不同。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "小嘉時鐘提供美學時鐘顯示功能，包括全屏時鐘、翻頁時鐘、透明時鐘（相機預覽背景）及主畫面小組件。具體功能可能因裝置、系統版本及訂閱狀態而有所不同。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "小嘉クロックは、全画面時計、フリップ時計、透明時計（カメラプレビュー背景）、ホーム画面ウィジェットなどを提供します。機能は端末、OS、サブスクリプション状態により異なる場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Jia Clock은 전체 화면 시계, 플립 시계, 투명 시계(카메라 미리보기 배경), 홈 화면 위젯 등을 제공합니다. 기능은 기기, OS, 구독 상태에 따라 달라질 수 있습니다."
          }
        }
      }
    },
    "legal.terms.section.rules.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "User Conduct"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用户使用规则"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用者規則"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "利用上の注意"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이용 규칙"
          }
        }
      }
    },
    "legal.terms.section.rules.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You agree to use the App lawfully and not to misuse, reverse engineer, interfere with, or attempt unauthorized access to the App or related services. You are responsible for your device, network, and Apple ID security."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你应合法使用 App，不得滥用、逆向工程、干扰或试图未经授权访问 App 或相关服务。你需自行负责设备、网络及 Apple ID 的安全。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你應合法使用 App，不得濫用、逆向工程、干擾或試圖未經授權存取 App 或相關服務。你需自行負責裝置、網路及 Apple ID 的安全。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "法令に従って利用し、不正利用、リバースエンジニアリング、妨害、不正アクセスを行わないことに同意します。端末、ネットワーク、Apple ID の管理は利用者の責任です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱을 합법적으로 사용해야 하며, 남용·리버스 엔지니어링·방해·무단 접근을 해서는 안 됩니다. 기기, 네트워크, Apple ID 보안은 사용자 책임입니다."
          }
        }
      }
    },
    "legal.terms.section.pro.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro Features"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro 功能说明"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro 功能說明"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro 機能"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro 기능"
          }
        }
      }
    },
    "legal.terms.section.pro.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Certain features are available through Jia Clock Pro, such as premium themes and other advanced options marked in the app. Pro access requires an active subscription or lifetime purchase. Free features remain available without Pro."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "部分功能属于小嘉时钟 Pro，例如高级主题及 App 内标注的其他高级选项。Pro 需有效订阅或永久买断后方可使用。未解锁 Pro 时，免费功能仍可正常使用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "部分功能屬於小嘉時鐘 Pro，例如進階主題及 App 內標註的其他進階選項。Pro 需有效訂閱或永久買斷後方可使用。未解鎖 Pro 時，免費功能仍可正常使用。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プレミアムテーマなど、一部機能は Pro で提供されます。Pro 利用には有効なサブスクリプションまたは買い切りが必要です。無料機能は Pro なしでも利用できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "프리미엄 테마 등 일부 기능은 Pro에서 제공됩니다. Pro는 유효한 구독 또는 평생 구매가 필요합니다. 무료 기능은 Pro 없이도 이용할 수 있습니다."
          }
        }
      }
    },
    "legal.terms.section.subscriptions.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Subscriptions and Lifetime Purchase"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "订阅与永久买断"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "訂閱與永久買斷"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サブスクリプションと買い切り"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구독 및 평생 구매"
          }
        }
      }
    },
    "legal.terms.section.subscriptions.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro may be offered as monthly subscription, yearly subscription, or one-time lifetime purchase. Prices are shown in the app as returned by the App Store and may vary by region. Subscriptions automatically renew unless cancelled at least 24 hours before the end of the current billing period. You can manage or cancel subscriptions in your App Store account settings. Restore Purchases is available in the app."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro 可能以月度订阅、年度订阅或一次性永久买断形式提供。价格以 App Store 在 App 内返回的显示为准，可能因地区而异。订阅会在当前计费周期结束前至少 24 小时未取消的情况下自动续期。你可在 App Store 账户设置中管理或取消订阅。App 内提供「恢复购买」功能。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro 可能以月度訂閱、年度訂閱或一次性永久買斷形式提供。價格以 App Store 在 App 內返回的顯示為準，可能因地區而異。訂閱會在當前計費週期結束前至少 24 小時未取消的情況下自動續期。你可在 App Store 帳戶設定中管理或取消訂閱。App 內提供「恢復購買」功能。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro は月額・年額サブスクリプションまたは買い切りで提供される場合があります。価格は App Store の表示に従います。サブスクリプションは期間終了24時間前までにキャンセルしない限り自動更新されます。App Store 設定で管理でき、アプリ内で購入復元が可能です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro는 월간·연간 구독 또는 평생 일회성 구매로 제공될 수 있습니다. 가격은 App Store 표시를 따르며 지역별로 다를 수 있습니다. 구독은 현재 기간 종료 24시간 전까지 취소하지 않으면 자동 갱신됩니다. App Store 설정에서 관리할 수 있으며 앱에서 구매 복원이 가능합니다."
          }
        }
      }
    },
    "legal.terms.section.refunds.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Refunds"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "退款说明"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "退款說明"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "返金"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "환불"
          }
        }
      }
    },
    "legal.terms.section.refunds.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All purchases are processed by Apple. Refund requests must be submitted to Apple in accordance with Apple's policies. We cannot issue refunds directly."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有购买均由 Apple 处理。退款申请须按 Apple 政策向 Apple 提交，我们无法直接为你办理退款。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "所有購買均由 Apple 處理。退款申請須按 Apple 政策向 Apple 提交，我們無法直接為你辦理退款。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "購入は Apple が処理します。返金は Apple のポリシーに従い Apple に申請してください。当方から直接返金することはできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 구매는 Apple이 처리합니다. 환불은 Apple 정책에 따라 Apple에 요청해야 하며, 당사가 직접 환불할 수 없습니다."
          }
        }
      }
    },
    "legal.terms.section.limitations.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feature Availability and Limitations"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "功能限制说明"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "功能限制說明"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "機能の制限"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기능 제한"
          }
        }
      }
    },
    "legal.terms.section.limitations.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The App is provided on an 「as is」 and 「as available」 basis. We do not guarantee uninterrupted operation on all devices. Transparent Clock requires a compatible camera and user permission. Simulator or restricted devices may have limited functionality."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "App 按「现状」及「可用性」提供，我们不保证在所有设备上持续无中断运行。透明时钟需要兼容的摄像头及用户授权；模拟器或受限制设备可能功能受限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "App 按「現狀」及「可用性」提供，我們不保證在所有裝置上持續無中斷運行。透明時鐘需要相容的相機及使用者授權；模擬器或受限制裝置可能功能受限。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本アプリは「現状有姿」で提供されます。全端末での無停止動作を保証しません。透明時計には対応カメラと許可が必要で、シミュレータ等では制限がある場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱은 「있는 그대로」 제공됩니다. 모든 기기에서 중단 없는 동작을 보장하지 않습니다. 투명 시계는 호환 카메라와 사용자 권한이 필요하며, 시뮬레이터 등에서는 기능이 제한될 수 있습니다."
          }
        }
      }
    },
    "legal.terms.section.camera.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Transparent Clock and Camera"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "透明时钟与摄像头"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "透明時鐘與相機"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "透明時計とカメラ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "투명 시계와 카메라"
          }
        }
      }
    },
    "legal.terms.section.camera.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Transparent Clock uses the device camera for live on-device preview only when you enable the feature. By enabling it, you confirm you have the right to use the camera in your environment. See the Privacy Policy for detailed camera practices."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "透明时钟仅在你主动开启时使用设备摄像头进行本机实时预览。开启即表示你确认在当前环境中有权使用摄像头。摄像头相关细节请参阅隐私政策。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "透明時鐘僅在你主動開啟時使用裝置相機進行本機即時預覽。開啟即表示你確認在當前環境中有權使用相機。相機相關細節請參閱隱私政策。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "透明時計は、有効化した場合に端末カメラを端末内プレビューのみに使用します。有効化により、利用環境でカメラ使用が適切であることを確認したものとみなします。詳細はプライバシーポリシーを参照してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "투명 시계는 사용자가 켠 경우에만 기기 카메라를 기기 내 실시간 미리보기에 사용합니다. 활성화하면 해당 환경에서 카메라 사용 권리가 있음을 확인한 것으로 봅니다. 자세한 내용은 개인정보 처리방침을 참고하세요."
          }
        }
      }
    },
    "legal.terms.section.disclaimer.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Disclaimer"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "免责声明"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "免責聲明"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "免責事項"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "면책 조항"
          }
        }
      }
    },
    "legal.terms.section.disclaimer.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To the maximum extent permitted by law, we are not liable for indirect, incidental, or consequential damages arising from your use of the App. The App is a display tool and does not provide professional, medical, or emergency services."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在法律允许的最大范围内，我们不对因使用 App 产生的间接、附带或后果性损害承担责任。App 为显示工具，不提供专业、医疗或紧急服务。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在法律允許的最大範圍內，我們不對因使用 App 產生的間接、附帶或後果性損害承擔責任。App 為顯示工具，不提供專業、醫療或緊急服務。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "法令で許される最大限の範囲で、間接的・付随的・結果的損害について責任を負いません。本アプリは表示ツールであり、専門・医療・緊急サービスを提供しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "법이 허용하는 최대 범위 내에서 간접·부수·결과적 손해에 대해 책임지지 않습니다. 앱은 표시 도구이며 전문·의료·긴급 서비스를 제공하지 않습니다."
          }
        }
      }
    },
    "legal.terms.section.updates.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Changes to These Terms"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "协议更新"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "協議更新"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "規約の変更"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "약관 변경"
          }
        }
      }
    },
    "legal.terms.section.updates.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We may update these Terms from time to time. Material changes will be reflected in the app or App Store listing. Continued use after updates constitutes acceptance."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们可能不时更新本协议。重要变更会在 App 或 App Store 页面中体现。更新后继续使用即视为接受。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我們可能不時更新本協議。重要變更會在 App 或 App Store 頁面中體現。更新後繼續使用即視為接受。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本規約は随時更新される場合があります。重要な変更はアプリまたは App Store 掲載情報に反映されます。更新後の利用は同意とみなします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "본 약관은 수시로 업데이트될 수 있습니다. 중요 변경은 앱 또는 App Store 페이지에 반영됩니다. 변경 후 계속 사용하면 동의한 것으로 봅니다."
          }
        }
      }
    },
    "legal.terms.section.contact.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Contact"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "联系方式"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "聯絡方式"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "お問い合わせ"
          }
        },
        "ko": {
          "stringUnit": {
