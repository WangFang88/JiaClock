            "value": "문의"
          }
        }
      }
    },
    "legal.terms.section.contact.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For questions about these Terms, contact: support@example.com\n(Placeholder — replace with your official support email before App Store release.)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如对本协议有疑问，请联系：support@example.com\n（占位邮箱，上架 App Store 前请替换为正式客服邮箱。）"
          }
        },
        "zh-Hant": {
          "stringUnit": {
